generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  transactions   Transaction[]
  budgets        Budget[]
  smsImports     SMSImport[]
  reportSettings ReportSettings?
}

model Account {
  id        String   @id @default(cuid())
  name      String
  type      String   // e.g., 'checking', 'savings', 'credit'
  balance   Float    @default(0.0)
  isDefault Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // 'income', 'expense'
  category    String
  merchant    String?
  date        DateTime
  isRecurring Boolean  @default(false)
  
  // Optional relations
  accountId   String
  userId      String
  smsImportId String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  smsImport SMSImport? @relation(fields: [smsImportId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([accountId])
}

model Budget {
  id           String   @id @default(cuid())
  name         String
  limit        Float
  currentUsage Float    @default(0.0)
  category     String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SMSImport {
  id              String   @id @default(cuid())
  rawSmsText      String
  smsSender       String?
  parsedAmount    Float?
  parsedMerchant  String?
  parsedDate      DateTime?
  parsedType      String?
  upiReference    String?
  parseConfidence String   // 'HIGH', 'MEDIUM', 'LOW'
  importStatus    String   // 'PENDING', 'CONFIRMED', 'REJECTED'
  
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction?

  @@index([userId])
}

model ReportSettings {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailReports Boolean  @default(true)
  frequency    String   @default("monthly") // 'weekly', 'monthly'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
